{
  "name": "dataverse-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.js",
    "test:lab": "vitest run --config vitest.config.js --passWithNoTests=false src/lab/r3f/__tests__/labActivation.test.js src/lab/r3f/__tests__/labConfigSchema.test.js src/lab/r3f/__tests__/labSceneRegistry.test.js src/lab/r3f/__tests__/labPresetStore.test.js src/lab/r3f/__tests__/R3FLabShell.test.jsx src/lab/r3f/__tests__/R3FLabEntry.test.jsx",
    "test:lab:shell": "vitest run --config vitest.config.js --reporter=verbose --passWithNoTests=false src/lab/r3f/__tests__/R3FLabShell.test.jsx",
    "test:unit:moon-impact": "vitest run --config vitest.config.js src/components/universe/civilizationInspectorModel.test.js",
    "test:unit:civ-batch": "vitest run --config vitest.config.js src/components/universe/QuickGridOverlay.civilizations.test.jsx",
    "test:unit:civ-inspector": "vitest run --config vitest.config.js src/components/universe/civilizationInspectorModel.test.js",
    "test:e2e": "playwright test --config=playwright.config.mjs",
    "test:e2e:planet-builder": "playwright test --config=playwright.config.mjs e2e/planet-builder-wizard-smoke.spec.mjs",
    "test:e2e:auth-session": "playwright test --config=playwright.config.mjs e2e/staging/auth-session-real.smoke.spec.mjs",
    "test:e2e:workspace-starlock": "playwright test --config=playwright.config.mjs e2e/staging/workspace-starlock-wizard-grid.smoke.spec.mjs",
    "test:e2e:planet-moon-preview": "playwright test --config=playwright.config.mjs e2e/staging/planet-moon-preview.smoke.spec.mjs",
    "test:e2e:camera-focus-flow": "playwright test --config=playwright.config.mjs e2e/staging/camera-focus-flow.smoke.spec.mjs",
    "test:e2e:accessibility-preview": "playwright test --config=playwright.config.mjs e2e/staging/accessibility-preview.smoke.spec.mjs",
    "test:e2e:preview-performance": "playwright test --config=playwright.config.mjs e2e/staging/preview-performance.smoke.spec.mjs",
    "test:e2e:workspace-resume-preview": "playwright test --config=playwright.config.mjs e2e/staging/workspace-resume-preview.smoke.spec.mjs",
    "test:e2e:planet-civilization-mineral-workflow": "playwright test --config=playwright.config.mjs e2e/staging/planet-civilization-mineral-workflow.smoke.spec.mjs",
    "test:e2e:planet-civilization-mineral-quickpath": "playwright test --config=playwright.config.mjs e2e/staging/planet-civilization-mineral-quickpath.smoke.spec.mjs",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "lint:fix": "node ./node_modules/eslint/bin/eslint.js . --fix",
    "format": "node ./node_modules/prettier/bin/prettier.cjs . --write",
    "format:check": "node ./node_modules/prettier/bin/prettier.cjs . --check"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@react-spring/three": "^10.0.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "d3-force-3d": "^3.0.6",
    "postprocessing": "^6.38.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
